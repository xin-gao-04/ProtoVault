{
  "name": "protovault",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "pnpm --filter @protovault/contracts build && pnpm --filter @protovault/desktop dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @protovault/desktop build && pnpm --filter @protovault/desktop test:e2e",
    "typecheck": "pnpm -r typecheck",
    "release:check": "pnpm typecheck && pnpm test && pnpm build && pnpm test:e2e && pnpm core:configure && pnpm core:build && pnpm core:test",
    "core:configure": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/core.ps1 configure",
    "core:build": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/core.ps1 build",
    "core:test": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/core.ps1 test",
    "agent:loop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/agent-loop.ps1 quick",
    "agent:loop:status": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/agent-loop.ps1 status",
    "agent:loop:release": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/agent-loop.ps1 release"
  }
}
